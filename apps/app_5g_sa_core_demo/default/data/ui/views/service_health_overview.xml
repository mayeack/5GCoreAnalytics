<dashboard version="1.1">
  <label>5G SA Core - Service Health Overview</label>
  <description>Executive view of 5G Standalone Core health, subscriber impact, and active issues across all regions and network slices.</description>

  <fieldset submitButton="false">
    <input type="time" token="time_range" searchWhenChanged="true">
      <label>Time Range</label>
      <default>
        <earliest>-7d@d</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="selected_region" searchWhenChanged="true">
      <label>Region</label>
      <choice value="*">All Regions</choice>
      <default>*</default>
      <search>
        <query>index=fiveg_sa_core sourcetype="5g:service:kpi" | dedup region | sort region | table region</query>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </search>
      <fieldForLabel>region</fieldForLabel>
      <fieldForValue>region</fieldForValue>
    </input>
  </fieldset>

  <!-- Row 1: Key Performance Indicators -->
  <row>
    <panel>
      <title>Registration Success Rate</title>
      <single>
        <search>
          <query>index=fiveg_sa_core sourcetype="5g:service:kpi" region="$selected_region$"
| stats avg(registration_success_rate) as rate
| eval rate=round(rate, 1)</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="field">rate</option>
        <option name="numberPrecision">0.0</option>
        <option name="rangeColors">["0xdc4e41","0xf8be34","0x53a051"]</option>
        <option name="rangeValues">[95,99]</option>
        <option name="underLabel">Avg %</option>
        <option name="unit">%</option>
        <option name="useColors">1</option>
      </single>
    </panel>
    <panel>
      <title>Session Establishment Rate</title>
      <single>
        <search>
          <query>index=fiveg_sa_core sourcetype="5g:service:kpi" region="$selected_region$"
| stats avg(pdu_session_success_rate) as rate
| eval rate=round(rate, 1)</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="field">rate</option>
        <option name="numberPrecision">0.0</option>
        <option name="rangeColors">["0xdc4e41","0xf8be34","0x53a051"]</option>
        <option name="rangeValues">[95,99]</option>
        <option name="underLabel">Avg %</option>
        <option name="unit">%</option>
        <option name="useColors">1</option>
      </single>
    </panel>
    <panel>
      <title>Active Subscribers</title>
      <single>
        <search>
          <query>index=fiveg_sa_core sourcetype="5g:subscriber:experience" region="$selected_region$"
| stats latest(active_subscribers) as subs by region, slice, subscriber_segment
| stats sum(subs) as total</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="field">total</option>
        <option name="numberPrecision">0</option>
        <option name="underLabel">Subscribers</option>
        <option name="useColors">0</option>
      </single>
    </panel>
    <panel>
      <title>Critical Alerts</title>
      <single>
        <search>
          <query>index=fiveg_sa_core sourcetype="5g:core:alerts" severity=critical region="$selected_region$"
| stats count as total</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="field">total</option>
        <option name="numberPrecision">0</option>
        <option name="rangeColors">["0x53a051","0xf8be34","0xdc4e41"]</option>
        <option name="rangeValues">[0,3]</option>
        <option name="underLabel">Critical Alerts</option>
        <option name="useColors">1</option>
      </single>
    </panel>
  </row>

  <!-- Row 2: Service Health Trends -->
  <row>
    <panel>
      <title>Service Success Rates Over Time</title>
      <chart>
        <search>
          <query>index=fiveg_sa_core sourcetype="5g:service:kpi" region="$selected_region$"
| timechart span=1h avg(registration_success_rate) as "Registration %" avg(pdu_session_success_rate) as "Session Establishment %"</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Success Rate %</option>
        <option name="charting.axisY.minimumNumber">85</option>
        <option name="charting.axisY.maximumNumber">100</option>
      </chart>
    </panel>
    <panel>
      <title>Control Plane Latency</title>
      <chart>
        <search>
          <query>index=fiveg_sa_core sourcetype="5g:service:kpi" region="$selected_region$"
| timechart span=1h avg(control_plane_latency_ms) as "Avg Latency (ms)" max(control_plane_latency_ms) as "Peak Latency (ms)"</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Latency (ms)</option>
      </chart>
    </panel>
  </row>

  <!-- Row 3: Regional and Slice Breakdown -->
  <row>
    <panel>
      <title>Service Health by Region</title>
      <chart>
        <search>
          <query>index=fiveg_sa_core sourcetype="5g:service:kpi"
| stats avg(registration_success_rate) as "Registration %" avg(pdu_session_success_rate) as "Session %" by region</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="charting.axisTitleX.text">Region</option>
        <option name="charting.axisTitleY.text">Success Rate %</option>
        <option name="charting.axisY.minimumNumber">90</option>
        <option name="charting.axisY.maximumNumber">100</option>
      </chart>
    </panel>
    <panel>
      <title>Impact by Network Slice</title>
      <chart>
        <search>
          <query>index=fiveg_sa_core sourcetype="5g:service:kpi" region="$selected_region$"
| stats avg(packet_drop_pct) as "Packet Drop %" avg(session_drop_rate) as "Session Drop %" by slice</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="charting.axisTitleX.text">Network Slice</option>
        <option name="charting.axisTitleY.text">Drop Rate %</option>
      </chart>
    </panel>
  </row>

  <!-- Row 4: Active Issues -->
  <row>
    <panel>
      <title>Current Issues and Alerts</title>
      <table>
        <search>
          <query>index=fiveg_sa_core sourcetype="5g:core:alerts" region="$selected_region$"
| sort - _time
| head 20
| eval Time=strftime(_time, "%Y-%m-%d %H:%M")
| table Time severity region site nf_type nf_instance alert_name kpi_value threshold status correlation_id
| rename severity as Severity region as Region site as Site nf_type as "NF Type" nf_instance as Instance alert_name as Issue kpi_value as Value threshold as Threshold status as Status correlation_id as "Incident ID"</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="count">10</option>
      </table>
    </panel>
  </row>

</dashboard>
